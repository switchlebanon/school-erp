// ================================================================
// S³ ERP — Complete Database Schema v3
// ================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────

enum Role {
  ADMIN
  TEACHER
  PARENT
  STUDENT
  EMPLOYEE
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  TRANSFERRED
}

enum TeacherStatus {
  ACTIVE
  ON_LEAVE
  INACTIVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum FeeStatus {
  PAID
  PENDING
  OVERDUE
}

enum SalaryPaymentStatus {
  PAID
  PENDING
  CANCELLED
}

enum ExpenseStatus {
  PAID
  PENDING
  CANCELLED
}

enum ExpenseCategory {
  UTILITIES
  SUPPLIES
  MAINTENANCE
  RENT
  TRANSPORTATION
  EQUIPMENT
  MARKETING
  INSURANCE
  OTHER
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  INACTIVE
}

enum Department {
  ADMINISTRATION
  TEACHING_SUPPORT
  FINANCE
  FACILITIES
  IT
  SECURITY
  TRANSPORT
  HEALTH
  OTHER
}

enum AnnouncementType {
  ACADEMIC
  EVENT
  ADMIN
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Weekday {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum PromotionStatus {
  PROMOTED
  RETAINED
  TRANSFERRED
  GRADUATED
}

enum MessageFolder {
  INBOX
  SENT
  ARCHIVED
}

enum ConstraintType {
  UNAVAILABLE
  NO_LAST_PERIOD
  NO_FIRST_PERIOD
  LATE_START
  EARLY_FINISH
  BEFORE_BREAK_ONLY
  AFTER_BREAK_ONLY
  DAY_OFF
  MAX_PER_DAY
  MAX_CONSECUTIVE
  MIN_REST
  PREFER_MORNING
  PREFER_AFTERNOON
  BALANCED_DAYS
  MORNING_SUBJECT
  AFTERNOON_SUBJECT
  PREFERRED_DAY
}

// ─── Core Identity ───────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      Role
  phone     String?
  avatarUrl String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher            Teacher?
  employee           Employee?
  salaryPayments     SalaryPayment[]    @relation("SalaryPaymentUser")
  studentsAsGuardian Student[]          @relation("GuardianStudents")
  studentAccount     Student?           @relation("StudentAccount")
  announcements      Announcement[]     @relation("AnnouncementAuthor")
  attendanceMarks    Attendance[]       @relation("AttendanceMarkedBy")
  expensesRecorded   Expense[]          @relation("ExpenseRecordedBy")
  sentMessages       Message[]          @relation("SentMessages")
  receivedMessages   MessageRecipient[] @relation("ReceivedMessages")

  @@map("users")
}

// ─── Academic Structure ──────────────────────────────────────────

model GradeLevel {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  order    Int
  sections Section[]

  @@map("grade_levels")
}

model Section {
  id           Int        @id @default(autoincrement())
  name         String
  gradeLevelId Int
  gradeLevel   GradeLevel @relation(fields: [gradeLevelId], references: [id])

  students            Student[]
  timetableEntries    TimetableEntry[]
  timetableSlots      TimetableSlot[]       @relation("TimetableSlots")
  classScheduleConfig ClassScheduleConfig?  @relation("ClassScheduleConfig")

  @@unique([gradeLevelId, name])
  @@map("sections")
}

model Subject {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  code  String? @unique
  color String?

  teacherSubjects  TeacherSubject[]
  timetableEntries TimetableEntry[]
  gradeRecords     GradeRecord[]
  grades           Grade[]
  timetableSlots   TimetableSlot[] @relation("TimetableSlotSubject")

  @@map("subjects")
}

// ─── People ──────────────────────────────────────────────────────

model Student {
  id             Int           @id @default(autoincrement())
  studentCode    String        @unique
  name           String
  dateOfBirth    DateTime?
  enrollmentDate DateTime      @default(now())
  status         StudentStatus @default(ACTIVE)
  guardianName   String?
  guardianPhone  String?

  sectionId Int
  section   Section @relation(fields: [sectionId], references: [id])

  guardianId Int?
  guardian   User? @relation("GuardianStudents", fields: [guardianId], references: [id])

  userId Int?  @unique
  user   User? @relation("StudentAccount", fields: [userId], references: [id])

  attendances  Attendance[]
  gradeRecords GradeRecord[]
  feeInvoices  FeeInvoice[]
  grades       Grade[]
  promotions   StudentPromotion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("students")
}

model Teacher {
  id              Int           @id @default(autoincrement())
  userId          Int           @unique
  user            User          @relation(fields: [userId], references: [id])
  status          TeacherStatus @default(ACTIVE)
  baseSalary      Decimal?      @db.Decimal(10, 2)
  maxHoursPerWeek Int?

  subjects         TeacherSubject[]
  timetableEntries TimetableEntry[]
  grades           Grade[]
  timetableSlots   TimetableSlot[]     @relation("TimetableSlotTeacher")
  constraints      TeacherConstraint[] @relation("TeacherConstraints")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teachers")
}

model TeacherSubject {
  id        Int     @id @default(autoincrement())
  teacherId Int
  teacher   Teacher @relation(fields: [teacherId], references: [id])
  subjectId Int
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, subjectId])
  @@map("teacher_subjects")
}

// ─── Staff / Payroll ─────────────────────────────────────────────

model Employee {
  id     Int            @id @default(autoincrement())
  userId Int            @unique
  user   User           @relation(fields: [userId], references: [id])
  status EmployeeStatus @default(ACTIVE)

  jobTitle   String
  department Department @default(OTHER)
  baseSalary Decimal?   @db.Decimal(10, 2)

  salaryPayments SalaryPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employees")
}

model SalaryPayment {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation("SalaryPaymentUser", fields: [userId], references: [id])

  employeeId Int?
  employee   Employee? @relation(fields: [employeeId], references: [id])

  month Int
  year  Int

  baseAmount    Decimal @db.Decimal(10, 2)
  bonus         Decimal @default(0) @db.Decimal(10, 2)
  bonusNote     String?
  deduction     Decimal @default(0) @db.Decimal(10, 2)
  deductionNote String?
  netAmount     Decimal @db.Decimal(10, 2)

  status   SalaryPaymentStatus @default(PENDING)
  paidDate DateTime?
  note     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month, year])
  @@map("salary_payments")
}

model Expense {
  id Int @id @default(autoincrement())

  category      ExpenseCategory @default(OTHER)
  description   String
  amount        Decimal         @db.Decimal(10, 2)
  vendor        String?
  paymentMethod String?
  status        ExpenseStatus   @default(PENDING)
  expenseDate   DateTime
  paidDate      DateTime?
  note          String?

  recordedById Int?
  recordedBy   User? @relation("ExpenseRecordedBy", fields: [recordedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("expenses")
}

// ─── Attendance ──────────────────────────────────────────────────

model Attendance {
  id        Int              @id @default(autoincrement())
  studentId Int
  student   Student          @relation(fields: [studentId], references: [id])
  date      DateTime         @db.Date
  status    AttendanceStatus @default(PRESENT)
  reason    String?

  markedById Int?
  markedBy   User? @relation("AttendanceMarkedBy", fields: [markedById], references: [id])

  createdAt DateTime @default(now())

  @@unique([studentId, date])
  @@index([date])
  @@map("attendance")
}

// ─── Grades / Exams ──────────────────────────────────────────────

model GradeRecord {
  id        Int     @id @default(autoincrement())
  studentId Int
  student   Student @relation(fields: [studentId], references: [id])
  subjectId Int
  subject   Subject @relation(fields: [subjectId], references: [id])

  term     String
  score    Float
  maxScore Float @default(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, subjectId, term])
  @@map("grade_records")
}

// ─── Fees / Finance ──────────────────────────────────────────────

model FeeInvoice {
  id        Int       @id @default(autoincrement())
  studentId Int
  student   Student   @relation(fields: [studentId], references: [id])

  description String
  amount      Decimal   @db.Decimal(10, 2)
  dueDate     DateTime  @db.Date
  status      FeeStatus @default(PENDING)
  totalPaid   Decimal   @default(0) @db.Decimal(10, 2)

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("fee_invoices")
}

model Payment {
  id        Int        @id @default(autoincrement())
  invoiceId Int
  invoice   FeeInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amount   Decimal  @db.Decimal(10, 2)
  paidDate DateTime @default(now()) @db.Date
  note     String?

  createdAt DateTime @default(now())

  @@map("payments")
}

// ─── Timetable (original) ────────────────────────────────────────

model TimetableEntry {
  id        Int      @id @default(autoincrement())
  sectionId Int
  section   Section  @relation(fields: [sectionId], references: [id])
  subjectId Int
  subject   Subject  @relation(fields: [subjectId], references: [id])
  teacherId Int?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  day       Weekday
  startTime String
  endTime   String

  @@unique([sectionId, day, startTime])
  @@map("timetable_entries")
}

// ─── Announcements ───────────────────────────────────────────────

model Announcement {
  id       Int              @id @default(autoincrement())
  title    String
  body     String?
  type     AnnouncementType @default(ACADEMIC)
  priority Priority         @default(MEDIUM)

  authorId Int?
  author   User? @relation("AnnouncementAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())

  @@map("announcements")
}

// ─── Academic Year & Terms ───────────────────────────────────────

model AcademicYear {
  id        String   @id @default(cuid())
  name      String   @unique
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())

  terms      Term[]
  promotions StudentPromotion[]
}

model Term {
  id             String       @id @default(cuid())
  name           String
  startDate      DateTime
  endDate        DateTime
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  grades Grade[]

  @@unique([academicYearId, name])
}

model Grade {
  id          String   @id @default(cuid())
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id])
  subjectId   Int
  subject     Subject  @relation(fields: [subjectId], references: [id])
  termId      String
  term        Term     @relation(fields: [termId], references: [id])
  teacherId   Int?
  teacher     Teacher? @relation(fields: [teacherId], references: [id])

  score       Float
  letterGrade String?
  comment     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, subjectId, termId])
}

model StudentPromotion {
  id             String          @id @default(cuid())
  studentId      Int
  student        Student         @relation(fields: [studentId], references: [id])
  academicYearId String
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id])
  fromGradeLevel String
  toGradeLevel   String
  fromClassId    String
  toClassId      String?
  promotedAt     DateTime        @default(now())
  promotedBy     String?
  status         PromotionStatus @default(PROMOTED)
  notes          String?
}

// ─── Messaging ───────────────────────────────────────────────────

model Message {
  id        String   @id @default(cuid())
  senderId  Int
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
  subject   String
  body      String   @db.Text
  createdAt DateTime @default(now())

  recipients MessageRecipient[]
}

model MessageRecipient {
  id          String        @id @default(cuid())
  messageId   String
  message     Message       @relation(fields: [messageId], references: [id])
  recipientId Int
  recipient   User          @relation("ReceivedMessages", fields: [recipientId], references: [id])
  isRead      Boolean       @default(false)
  readAt      DateTime?
  isDeleted   Boolean       @default(false)
  folder      MessageFolder @default(INBOX)
}

// ─── Auto Timetable ──────────────────────────────────────────────

model TimetableConfig {
  id               String   @id @default(cuid())
  name             String
  academicYearId   String?
  daysPerWeek      Int      @default(5)
  periodsPerDay    Int      @default(7)
  periodDuration   Int      @default(45)
  startTime        String   @default("07:30")
  breakAfterPeriod Int?
  isActive         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  slots        TimetableSlot[]
  constraints  TeacherConstraint[]
  classConfigs ClassScheduleConfig[]
}

model TimetableSlot {
  id       String @id @default(cuid())
  configId String
  config   TimetableConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  sectionId Int
  section   Section @relation("TimetableSlots", fields: [sectionId], references: [id])

  subjectId Int
  subject   Subject @relation("TimetableSlotSubject", fields: [subjectId], references: [id])

  teacherId Int
  teacher   Teacher @relation("TimetableSlotTeacher", fields: [teacherId], references: [id])

  day      Int
  period   Int
  isDouble Boolean @default(false)
  isLocked Boolean @default(false)

  @@unique([configId, sectionId, day, period])
  @@unique([configId, teacherId, day, period])
}

model TeacherConstraint {
  id       String @id @default(cuid())
  configId String
  config   TimetableConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  teacherId Int
  teacher   Teacher @relation("TeacherConstraints", fields: [teacherId], references: [id])

  type   ConstraintType
  day    Int?
  period Int?
  value  String?
  note   String?

  @@map("teacher_constraints")
}

model ClassScheduleConfig {
  id              String          @id @default(cuid())
  sectionId       Int             @unique
  section         Section         @relation("ClassScheduleConfig", fields: [sectionId], references: [id])
  configId        String
  timetableConfig TimetableConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  periodsPerDay     Int    @default(7)
  sessionDuration   Int    @default(45)
  breakAfterPeriods String @default("4")
  breakDurations    String @default("15")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("class_schedule_configs")
}
